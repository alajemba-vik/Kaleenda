# Kaleenda — environment variables
#
# --- Project URL & API keys (Supabase Dashboard) ---
# Settings → API Keys
#   - Project URL  → VITE_SUPABASE_URL and SUPABASE_URL (same value)
#   - If you still use legacy JWT-based keys: copy "anon" and "service_role"
#     into VITE_SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY.
#   - You can ignore "publishable/secret" keys unless you migrate the app to them.
#
# --- JWT secret for /api/auth/session (HS256 signing) ---
# Settings → JWT Keys
#   Supabase migrated the old "JWT secret" into this page. You need the
#   symmetric signing secret that PostgREST uses to verify Bearer tokens.
#   Look for the current signing key / JWT secret (often HS256 or "shared secret").
#   Copy it into SUPABASE_JWT_SECRET — it replaces the old "Legacy JWT secret"
#   from the pre-migration settings.
#
# If the dashboard only shows asymmetric keys (RSA/EC) and no copyable secret,
# open the JWT Keys docs from Supabase or support: Kaleenda signs HS256 tokens
# and must use the same verification material your project uses for API JWTs.

# Browser (Vite) — safe to expose
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
VITE_EMAIL_ENABLED=false

# Server (Vercel env + local vite-plugin-session-api) — never expose to the client
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=YOUR_JWT_SIGNING_SECRET_FROM_JWT_KEYS_PAGE
